# Flask
FLASK_ENV=production
SECRET_KEY=change-me
DATABASE_URL=sqlite:///app.db

# Jira Data Center base URL (no trailing slash)
JIRA_BASE_URL=https://jira.example.com
JIRA_AUTOMATION_ACTOR_ACCOUNT_ID=JIRAUSER_SERVICE_ACCOUNT
JIRA_PAT_VALIDATION_CACHE_SECONDS=300

# Admin email shown for forgot password
ADMIN_EMAIL=admin@example.com

# Encryption key for PAT storage
# Generate with:
#   py -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generated-fernet-key

# Security cookie flags
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# Session timeout
SESSION_TIMEOUT_MINUTES=15
SESSION_WARNING_THRESHOLD_RATIO=0.8

# Tableau
TABLEAU_BASE_URL=https://tableau.example.com
TABLEAU_API_VERSION=3.25
TABLEAU_SITE_CONTENT_URL=

# Structured logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_BACKUPS=14
LOG_TO_CONSOLE=false
LOG_TIMEZONE=Asia/Kolkata
LOG_FORMAT=json
LOG_WERKZEUG_LEVEL=WARNING
LOG_URLLIB3_LEVEL=WARNING
LOG_SQLALCHEMY_LEVEL=WARNING

# Diagnostic tracing. Keep false in production unless actively debugging.
TRACE_SPRINT_VIEWER=false
TRACE_JIRA_JQL=false
TRACE_SPRINT_VIEWER_API=false
TRACE_SPRINT_VIEWER_UI=false

# External Jira/Tableau HTTP retry behavior.
EXTERNAL_HTTP_TIMEOUT_SECONDS=20
EXTERNAL_HTTP_RETRY_TOTAL=3
EXTERNAL_HTTP_RETRY_BACKOFF_SECONDS=0.5
EXTERNAL_HTTP_RETRY_STATUS_CODES=429,500,502,503,504

# Legacy route retirement headers.
LEGACY_ROUTE_DEPRECATION_HEADERS=true
LEGACY_ROUTE_SUNSET=

# Sprint metrics parallelism.
SPRINT_METRICS_MAX_WORKERS=5
